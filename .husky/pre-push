# ── Fast gate: catch NEXT.md / version issues before running any tests ──
echo "🔒 Running pre-push gate (NEXT.md + version check)..."
if ! node scripts/pre-push-gate.js; then
  exit 1
fi

# ── Smoke tier: run only tests affected by files changed vs origin/main ──
# Full suite still runs in CI across 8 sharded runners — that's the authority.
# Pre-push is a fast signal to catch obvious breakage before it costs a CI run.
#
# Opt out (full suite locally): INSTAR_PRE_PUSH_FULL=1 git push
# Opt out (skip tests entirely): INSTAR_PRE_PUSH_SKIP=1 git push

if [ "${INSTAR_PRE_PUSH_SKIP:-}" = "1" ]; then
  echo "⏭️  INSTAR_PRE_PUSH_SKIP=1 — skipping pre-push tests (CI will still run them)."
  exit 0
fi

# Ensure the base ref we diff against is fresh.
git fetch --quiet origin main 2>/dev/null || true

if [ "${INSTAR_PRE_PUSH_FULL:-}" = "1" ]; then
  echo "🧪 INSTAR_PRE_PUSH_FULL=1 — running full push suite (slow, ~10 min)..."
  TEST_CMD="npm run test:push"
else
  echo "🧪 Running smoke tier (tests affected by changes vs origin/main)..."
  echo "   Full suite runs in CI | Force full locally: INSTAR_PRE_PUSH_FULL=1 git push"
  TEST_CMD="npm run test:smoke"
fi

# Try up to 2 times — flaky tests may fail intermittently
for attempt in 1 2; do
  if $TEST_CMD; then
    exit 0
  fi
  if [ "$attempt" -eq 1 ]; then
    echo ""
    echo "⚠️  Attempt 1 failed — retrying once (intermittent failures suspected)..."
    echo ""
  fi
done

echo "❌ Tests failed on both attempts. Debug with: $TEST_CMD"
exit 1
