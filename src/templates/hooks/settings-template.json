{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/telegram-topic-context.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/dangerous-command-guard.sh \"$TOOL_INPUT\"",
            "blocking": true
          },
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/grounding-before-messaging.sh \"$TOOL_INPUT\"",
            "blocking": true
          },
          {
            "type": "command",
            "command": "node .instar/hooks/instar/deferral-detector.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node .instar/hooks/instar/external-communication-guard.js",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node .instar/hooks/instar/external-operation-gate.js",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/free-text-guard.sh",
            "blocking": true,
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/session-start.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/session-start.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .instar/hooks/instar/instructions-loaded-tracker.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .instar/hooks/instar/skill-usage-telemetry.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .instar/hooks/instar/subagent-start-tracker.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .instar/hooks/instar/response-review.js",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .instar/hooks/instar/claim-intercept-response.js",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .instar/hooks/instar/scope-coherence-checkpoint.js",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
