{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agent-kit/hooks/dangerous-command-guard.sh \"$TOOL_INPUT\"",
            "blocking": true
          },
          {
            "type": "command",
            "command": "bash .agent-kit/hooks/grounding-before-messaging.sh \"$TOOL_INPUT\"",
            "blocking": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agent-kit/hooks/session-start.sh",
            "blocking": false
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "compaction",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agent-kit/hooks/compaction-recovery.sh",
            "blocking": false
          }
        ]
      }
    ]
  }
}
