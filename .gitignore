node_modules
dist/
*.js.map
*.d.ts.map

# Contract test evidence (local, ephemeral)
.contract-test-evidence.json

# Environment
.env
.env.local
.env.*.local

# Runtime state (generated by instar in target repos)
.instar/state/
.instar/logs/
.instar/telegram-inbound/
.instar/instar-dev-traces/
.instar/audit/
# Per-machine runtime data — downloaded user photos + local SQLite databases.
# Never committed; also where agent-data-spotlight-exclusion drops its markers.
.instar/telegram-images/
.instar/server-data/
# Coverage report — generated by scripts/docs-coverage.mjs, uploaded as a CI
# artifact. Not committed because it would churn on every PR and is fully
# reproducible from source.
.instar/docs-coverage.json
.instar/docs-coverage.md

# Integrated-Being ledger — per-machine, not synced across machines (spec §Multi-machine)
.instar/shared-state.jsonl
.instar/shared-state.jsonl.*

# TaskFlow registry — local SQLite + WAL/SHM. May contain user PII in stateJson.
# Cross-machine sync of flow state is not in v1 scope.
.instar/task-flows.db
.instar/task-flows.db-*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test artifacts
coverage/
.vitest/
.vercel
instar-*.tgz

# Secrets & credentials
data/relay-signing-key.json
data/registry.db
.mcpregistry_*
demo.tape
house-consciousness-framework/


# Phase 1c-build — private signing key for instar-default lock-file (NEVER commit)
.instar-release-keys/

# Generated build artifact (scripts/generate-builtin-manifest.cjs, run by `npm run build`
# + prepublishOnly). Not committed — avoids a hot-file merge-conflict loop on every
# skill/hook PR. Shipped via the .npmignore allowlist, regenerated before publish.
src/data/builtin-manifest.json

# MTP Red-Team Harness — engineered/pressure payloads are authored locally in a
# retired session at run-time, never committed (payload-by-reference, CMT-1115).
src/redteam/packs/*/payloads/L2.md
src/redteam/packs/*/payloads/L3.md
