{
  "permissions": {
    "allow": [
      "Bash(tmux:*)",
      "mcp__playwright__*",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Read(~/.dawn-server/**)",
      "Read(/tmp/dawn-telegram/**)",
      "Read(/tmp/dawn-**)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-approve-claude-edits.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-approve-claude-edits.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-approve-claude-edits.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
