        "description": "User-authored",
        "schedule": "0 12 * * *",
        "priority": "medium",
        "expectedDurationMinutes": 1,
        "model": "haiku",
        "enabled": false,
        "execute": { "type": "prompt", "value": "User prompt gamma (disabled)\n" }
      }
    },
    {
      "kind": "add-job",
      "entry": {
        "slug": "user-job-delta",
