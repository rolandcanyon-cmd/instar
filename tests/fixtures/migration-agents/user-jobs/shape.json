      }
    },
    {
      "kind": "add-job",
      "entry": {
        "slug": "user-job-epsilon",
        "name": "User Job Epsilon",
        "description": "User-authored",
        "schedule": "30 4 * * *",
        "priority": "low",
        "expectedDurationMinutes": 1,
        "model": "haiku",
        "enabled": true,
        "execute": { "type": "prompt", "value": "User prompt epsilon\n" }
      }
    }
