        "schedule": "0 9 * * *",
        "priority": "medium",
        "expectedDurationMinutes": 2,
        "model": "sonnet",
        "enabled": true,
        "execute": { "type": "prompt", "value": "User prompt beta\n" }
      }
    },
    {
      "kind": "add-job",
      "entry": {
        "slug": "user-job-gamma",
