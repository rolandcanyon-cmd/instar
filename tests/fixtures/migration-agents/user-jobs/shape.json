{
  "name": "user-jobs",
  "description": "Five user-authored jobs alongside the standard defaults.",
  "baseJobsSource": "getDefaultJobs",
  "transformations": [
    {
      "kind": "add-job",
      "entry": {
        "slug": "user-job-alpha",
        "name": "User Job Alpha",
        "description": "User-authored",
        "schedule": "*/10 * * * *",
        "priority": "low",
        "expectedDurationMinutes": 1,
        "model": "haiku",
        "enabled": true,
        "execute": { "type": "prompt", "value": "User prompt alpha\n" }
      }
    },
    {
      "kind": "add-job",
      "entry": {
        "slug": "user-job-beta",
